@startuml Representatives
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

Person(PAO, "Port Authority Officer", "System user managing port authority operations")

Container_Boundary(representativeapi, "Representative API") {
    Component(RepresentativeController, "Representative Controller", "ASP.NET Core MVC Controller", "Handles HTTP requests related to Vessels")
    Component(RepresentativeService, "Representative Service", ".NET 8 (ASP.NET Core)", "Business logic for Vessels")
    Component(Representative, "Representative", "Domain Model", "Represents a Representative")
    Component(RepresentativeRepository, "Representative Repository", ".NET 8 (ASP.NET Core)", "Data access for Vessels")
    ComponentDb(db, "Shipping Management Database", "SQL Server", "Stores all data related to shipping management")

    Component(ShippingAgentOrganizationRepository, "Shipping Agent Organization Repository", ".NET 8 (ASP.NET Core)", "Data access for VesselTypes")
    Component(DbContext, "DbContext", ".NET 8 (Entity Framework Core)", "EF Core DbContext for Shipping Management")
}


RepresentativeService -[hidden]right-> Representative
RepresentativeRepository -[hidden]right-> DbContext


Rel(PAO, RepresentativeController, "Sends HTTP requests", "HTTPS/JSON")
Rel(RepresentativeController, RepresentativeService, "Calls methods in", "Method Calls")
Rel(RepresentativeService, Representative, "Uses", "Domain Logic")
Rel(RepresentativeService, RepresentativeRepository, "Uses", "Method Calls")
Rel(RepresentativeRepository, DbContext, "Uses", "Method Calls")

Rel(RepresentativeService, ShippingAgentOrganizationRepository, "Uses", "Method Calls")
Rel(ShippingAgentOrganizationRepository, DbContext, "Uses", "Method Calls")
Rel(DbContext, db, "Reads from and writes to", "EF Core/SQL")

@enduml