@startuml

left to right direction
skinparam actorStyle awesome
"Port Authority Officer" as PAO
"Shipping Agent Representative" as SAR
"Logistics Operator" as LO
"Administrator" as Admin
"Project Manager" as PM
"System User" as SU
"Non-Authenticated\nSystem User" as NAU
"Port Operations Supervisor" as POS

package UC4.1{
    usecase "UC4.1.1: Develop Operations & Execution \nManagement (OEM) module." as UC4_1_1
    usecase "UC4.1.2: Automatically generate and store \nOperation Plans for all Vessel Visit Notifications." as UC4_1_2
    usecase "UC4.1.3: Search and list Operation Plans for \na given day or period." as UC4_1_3
    usecase "UC4.1.4: Update the Operation Plan of a given VVN." as UC4_1_4
    usecase "UC4.1.5: Identify Vessel Visit Notifications \n(VVNs) that do not yet have an Operation Plan." as UC4_1_5
    usecase "UC4.1.7: Create a Vessel Visit Execution (VVE) \nrecord when a vessel arrives at the port." as UC4_1_7
    usecase "UC4.1.8: Update an in progress VVE with the \nactual berth time and dock used." as UC4_1_8
    usecase "UC4.1.9: Update an in progress VVE with \nexecuted operations." as UC4_1_9
    usecase "UC4.1.10: Search and list VVEs over a given \nperiod or for a specific vessel." as UC4_1_10
    usecase "UC4.1.12: Manage the catalog of Incident Types." as UC4_1_12
    usecase "UC4.1.13: Record and manage incidents that \naffect the execution of port operations." as UC4_1_13
    usecase "UC4.1.14: Manage the catalog of Complementary \nTask Categories." as UC4_1_14
    usecase "UC4.1.15: Record and manage Complementary \nTasks performed during vessel visits." as UC4_1_15
}

