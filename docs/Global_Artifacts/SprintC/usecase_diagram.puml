SU --> UC4_2_3
LO --> UC4_2_4
SU --> UC4_2_5

package UC4.3{
    usecase "UC4.3.1: Want the scheduling module to include a genetic \nalgorithm–based approach to generate optimized \ndaily operation plans." as UC4_3_1
    usecase "UC4.3.2: Want the system to automatically select the most \nsuitable scheduling algorithm (optimal, \nheuristic, or genetic)." as UC4_3_2
    usecase "UC4.3.3: Want the system to rebalance the distribution of \napproved Vessel Visit Notifications across available \ndocks for a given day." as UC4_3_3
    usecase "UC4.3.4: Want the team to study the state of the art and \npotential applications of Robotics and Computer Vision \nin port logistics and administration." as UC4_3_4
    usecase "UC4.3.5: Want the team to produce a short explanatory \nvideo that illustrates how the developed system schedules \nand sequences vessel loading and unloading operations \nat port docks." as UC4_3_5
}

