LO --> UC4_1_9
LO --> UC4_1_10
PAO --> UC4_1_12
LO --> UC4_1_13
POS --> UC4_1_14
LO --> UC4_1_15

package UC4.2{
    usecase "UC4.2.1: Select a port facility by left-clicking \non its 3D representation (object picking)." as UC4_2_1
    usecase "UC4.2.2: Want to select vessels and major operational \nresources by left-clicking on their 3D representations." as UC4_2_2
    usecase "UC4.2.3: Whenever I press the “i” key, I want to toggle \nan information overlay showing updated information." as UC4_2_3
    usecase "UC4.2.4: Want to see the current operational status \nof vessels (e.g., waiting, loading, unloading)." as UC4_2_4
    usecase "UC4.2.5: Want a dynamic spotlight to follow the camera \nand illuminate the selected element’s center point." as UC4_2_5
}

